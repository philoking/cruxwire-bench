# Bench configuration. Copy to .env (compose reads it) and adjust.

# Shared volume: read-only mount of cruxwire's corpus archive.
BENCH_CORPUS_DIR=./data/corpus

# Bench-private volume: marks store, multi-model embeddings, run records.
BENCH_DATA_DIR=./data/bench

# Ollama on Nova, for the overnight GPU re-embed batch (never hit interactively).
OLLAMA_HOST=http://localhost:11434

# Web service bind.
BENCH_HOST=0.0.0.0
BENCH_PORT=8800
